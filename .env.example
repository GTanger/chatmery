# 複製為 .env 並填入真實值，.env 已加入 .gitignore 不會被 push
# cp .env.example .env
# 其餘設定（模型、後端、端點等）請寫在工作區 chatmery.tuning，見 chatmery.tuning.example
# 注意：值含特殊字元（如 &）或需多行時請用雙引號包住，且每行必須是 KEY=value，勿單獨一行只有值

# 搜尋：brave 或 tavily（擇一需 key）
BRAVE_API_KEY=
TAVILY_API_KEY=

# 聊天後端為 openai 時
OPENAI_API_KEY=

# 聊天後端為 gemini 時（若 key 含特殊字元請用雙引號，例：GEMINI_API_KEY="AIzaSy..."）
GEMINI_API_KEY=

# 聊天後端為 openrouter 時
OPENROUTER_API_KEY=
