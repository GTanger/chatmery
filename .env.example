# 複製為 .env 並填入真實值，.env 已加入 .gitignore 不會被 push
# cp .env.example .env

# Telegram bot（必填）
TELEGRAM_BOT_TOKEN=

# 搜尋後端：brave 或 tavily（擇一，需對應 API key）
CHATMERY_SEARCH=brave
BRAVE_API_KEY=
TAVILY_API_KEY=

# 選填（預設針對約 4B 參數模型）
# CHATMERY_WORKSPACE=.
# CHATMERY_MODEL=qwen-4b-slim:latest
# OLLAMA_HOST=http://localhost:11434
# 時區（IANA，如 Asia/Taipei），模型回答日期／時間依此；空則用主機當地
# CHATMERY_TZ=Asia/Taipei

# 提煉（短期→長期）：短期超過幾條才觸發、一次送幾條、每條最多幾字（預設 20、15、120）
# CHATMERY_REFINE_ROLLOVER=20
# CHATMERY_REFINE_BATCH_MAX=15
# CHATMERY_REFINE_RUNES_PER_ITEM=120

# 向量檢索（語意相似）；空則用關鍵字。需 Ollama 已拉 embedding 模型，如 ollama pull nomic-embed-text
# CHATMERY_EMBED_MODEL=nomic-embed-text
# CHATMERY_EMBED_URL=
