# 複製為 .env 並填入真實值，.env 已加入 .gitignore 不會被 push
# cp .env.example .env

# Telegram bot（必填）
TELEGRAM_BOT_TOKEN=

# 搜尋後端：brave 或 tavily（擇一，需對應 API key）
CHATMERY_SEARCH=brave
BRAVE_API_KEY=
TAVILY_API_KEY=

# 選填（預設針對約 4B 參數模型）
# CHATMERY_WORKSPACE=.
# CHATMERY_MODEL=qwen-4b-slim:latest
# OLLAMA_HOST=http://localhost:11434
