# 複製為 chatmery.tuning 放在工作區，直觀調整數值；環境變數會覆寫此檔
# cp chatmery.tuning.example chatmery.tuning

# 模型與聊天後端（API key 一律放在 .env，此檔只寫設定）
CHATMERY_MODEL=gemma3:4b             # 模型名稱（ollama 本機，3.3GB/131K/吐字快；可改 mistral-nemo:12b、qwen-4b-slim 等）
OLLAMA_HOST=http://localhost:11434   # Ollama 服務網址（provider=ollama 時用）
CHATMERY_PROVIDER=ollama             # 聊天後端：ollama | openai | gemini | openrouter（後三者需在 .env 設對應 API key）
# OPENAI_BASE_URL=https://api.openai.com/v1   # 選填；openai 時預設為此
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta   # 選填；gemini 時預設為此
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # 選填；openrouter 時預設為此；模型名見 https://openrouter.ai/models

# 等候回覆時的文案（多句用 | 分隔，每次隨機選一句；空則用內建「八百里加急吐字中🐎」）
CHATMERY_PLACEHOLDER=八百里加急吐字中🐎|稍候，馬兒在跑|正在想⋯|馬上好

# 搜尋後端（API key 仍用 .env）
CHATMERY_SEARCH=brave                # 網搜後端：brave 或 tavily
CHATMERY_SEARCH_QUERY_LLM=true       # Cursor 式：用 LLM 依句意產出搜尋 query；false 則用關鍵字

# 對話與記憶
CHATMERY_RECENT_TURNS=20             # 送進模型的近期對話輪次上限（1–100），預設 20
CHATMERY_MEMORY_AUTO_SHORT=true      # 是否每 20 輪濃縮 1 句進短期（false=關閉自動解構進短期）
CHATMERY_MEMORY_AUTO_LONG=true       # 短期滿時是否濃縮進長期→核心→靈魂（false=僅寫短期、不觸發長鏈）

# 記憶注入量（答覆結構：當前1+靈魂1+核心2+長期3+短期5）
CHATMERY_MEMORY_LONG_K=3             # 長期記憶最多取幾條注入 prompt
CHATMERY_MEMORY_SESSION_K=5          # 短期最多取幾條（當前 session）
# CHATMERY_MEMORY_CORE_K=2           # 核心最多取幾條（預設 2）
# CHATMERY_MEMORY_SHORT_K=5          # 短期池檢索最多取幾條（預設 5）
CHATMERY_WEB_SEARCH_MAX=5            # 網搜最多幾條結果
CHATMERY_SNIPPET_MAX=120             # 每條記憶/搜尋結果最多幾字（0=不截）

# 提煉（短期事實超過 rollover 才觸發，一次送幾條、每條最多幾字）
CHATMERY_REFINE_ROLLOVER=20          # 短期事實超過此條數才提煉進長期
CHATMERY_REFINE_BATCH_MAX=15         # 提煉時一次送幾條給模型
CHATMERY_REFINE_RUNES_PER_ITEM=120   # 提煉時每條內容最多幾字

# 四池一魂：池容量與濃縮後條數（短期滿→濃縮進長期；長期滿→核心；核心滿→靈魂）
# CHATMERY_SHORT_TERM_CAP=200        # 短期池上限
# CHATMERY_SHORT_CONDENSE_TO=50      # 短期滿後濃縮成幾句進長期
# CHATMERY_LONG_TERM_CAP=100         # 長期池上限
# CHATMERY_LONG_CONDENSE_TO=5        # 長期滿後濃縮成幾句進核心
# CHATMERY_CORE_CAP=20               # 核心池上限
# CHATMERY_CORE_CONDENSE_TO=1        # 核心滿後濃縮成 1 句進靈魂

# 時區（模型回答日期/時間用；IANA 名稱）
CHATMERY_TZ=Asia/Taipei              # 例：Asia/Taipei、America/New_York；空則用主機當地

# 輸出語言（回覆一律使用此語言；留空=不限制）
CHATMERY_OUTPUT_LANG=繁體中文        # 例：繁體中文、English；空則不限制

# 模型知識庫（RAG + Obsidian 蒲公英連結）
CHATMERY_KNOWLEDGE_ENABLED=true     # 是否啟用知識庫檢索並注入
# CHATMERY_KNOWLEDGE_PATH=           # 空則 {workspace}/knowledge
CHATMERY_KNOWLEDGE_TOP_K=5           # 檢索最多幾條
CHATMERY_KNOWLEDGE_CHUNK_RUNES=400   # 攝入時每段字數
CHATMERY_KNOWLEDGE_OVERLAP=50        # 相鄰段重疊字數
CHATMERY_KNOWLEDGE_EXPAND_LINKS=true # 沿 [[連結]] 擴散檢索（蒲公英）
CHATMERY_KNOWLEDGE_EXPAND_MAX=5     # 擴散最多再加幾條

# 向量檢索（語意相似：不記得句子、記得內容；空則用關鍵字檢索）
CHATMERY_EMBED_MODEL=                # 模型名；ollama: nomic-embed-text；openai: text-embedding-3-small；gemini: text-embedding-004；空=關閉
CHATMERY_EMBED_PROVIDER=ollama      # ollama（預設）| openai | gemini；openai/gemini 時需在 .env 設對應 API key
# CHATMERY_EMBED_URL=                # 僅 ollama 時用；空則同 OLLAMA_HOST
